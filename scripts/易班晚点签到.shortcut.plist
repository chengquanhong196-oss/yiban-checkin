<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>WFWorkflowClientVersion</key>
    <string>900.6</string>
    <key>WFWorkflowClientRelease</key>
    <string>2.1</string>
    <key>WFWorkflowMinimumClientVersion</key>
    <integer>900</integer>
    <key>WFWorkflowIcon</key>
    <dict>
        <key>WFWorkflowIconStartColor</key>
        <integer>144202270</integer>
        <key>WFWorkflowIconGlyphNumber</key>
        <integer>59769</integer>
    </dict>
    <key>WFWorkflowImportQuestions</key>
    <array>
        <dict>
            <key>Category</key>
            <string>Parameter</string>
            <key>ActionIndex</key>
            <integer>3</integer>
            <key>ParameterKey</key>
            <string>WFApp</string>
            <key>Text</key>
            <string>请选择易班 app</string>
        </dict>
    </array>
    <key>WFWorkflowTypes</key>
    <array>
        <string>Sleep</string>
        <string>Watch</string>
    </array>
    <key>WFWorkflowInputContentItemClasses</key>
    <array>
        <string>WFAppStoreAppContentItem</string>
    </array>
    <key>WFWorkflowActions</key>
    <array>
        <!-- 1. 获取当前位置 -->
        <dict>
            <key>WFWorkflowActionIdentifier</key>
            <string>is.workflow.actions.getcurrentlocation</string>
            <key>WFWorkflowActionParameters</key>
            <dict>
                <key>WFLocationAccuracy</key>
                <string>HundredMeters</string>
            </dict>
        </dict>

        <!-- 2. 计算到福州大学晋江校区的距离 -->
        <dict>
            <key>WFWorkflowActionIdentifier</key>
            <string>is.workflow.actions.getdistance</string>
            <key>WFWorkflowActionParameters</key>
            <dict>
                <key>WFGetDistanceFrom</key>
                <dict>
                    <key>Value</key>
                    <dict>
                        <key>OutputName</key>
                        <string>当前位置</string>
                        <key>OutputUUID</key>
                        <string>location-output</string>
                        <key>Type</key>
                        <string>ActionOutput</string>
                    </dict>
                    <key>WFSerializationType</key>
                    <string>WFTextTokenAttachment</string>
                </dict>
                <key>WFGetDistanceTo</key>
                <dict>
                    <key>Value</key>
                    <dict>
                        <key>isVariable</key>
                        <false/>
                        <key>Value</key>
                        <dict>
                            <key>street</key>
                            <string>福州大学晋江校区</string>
                            <key>city</key>
                            <string>泉州市</string>
                            <key>state</key>
                            <string>福建省</string>
                            <key>country</key>
                            <string>中国</string>
                            <key>latitude</key>
                            <real>24.571</real>
                            <key>longitude</key>
                            <real>118.617</real>
                        </dict>
                    </dict>
                    <key>WFSerializationType</key>
                    <string>WFTextTokenString</string>
                </dict>
                <key>WFGetDistanceUnit</key>
                <string>Meters</string>
            </dict>
        </dict>

        <!-- 3. 判断距离是否小于500米 -->
        <dict>
            <key>WFWorkflowActionIdentifier</key>
            <string>is.workflow.actions.conditional</string>
            <key>WFWorkflowActionParameters</key>
            <dict>
                <key>WFCondition</key>
                <integer>2</integer>
                <key>WFConditionalCondition</key>
                <dict>
                    <key>Value</key>
                    <dict>
                        <key>Type</key>
                        <string>Number</string>
                        <key>Value</key>
                        <real>500</real>
                    </dict>
                    <key>WFSerializationType</key>
                    <string>WFTextTokenString</string>
                </dict>
                <key>WFControlFlowMode</key>
                <integer>0</integer>
            </dict>
        </dict>

        <!-- 4. 在范围内 → 打开易班 -->
        <dict>
            <key>WFWorkflowActionIdentifier</key>
            <string>is.workflow.actions.openapp</string>
            <key>WFWorkflowActionParameters</key>
            <dict>
                <key>WFApp</key>
                <dict>
                    <key>BundleIdentifier</key>
                    <string>cn.yiban.mainAPP</string>
                    <key>Name</key>
                    <string>易班</string>
                </dict>
                <key>WFSerializationType</key>
                <string>WFTextTokenString</string>
            </dict>
        </dict>

        <!-- 5. 等待2秒让app加载 -->
        <dict>
            <key>WFWorkflowActionIdentifier</key>
            <string>is.workflow.actions.wait</string>
            <key>WFWorkflowActionParameters</key>
            <dict>
                <key>WFWaitTime</key>
                <integer>2</integer>
            </dict>
        </dict>

        <!-- 6. 通知：请选择学校 -->
        <dict>
            <key>WFWorkflowActionIdentifier</key>
            <string>is.workflow.actions.notification</string>
            <key>WFWorkflowActionParameters</key>
            <dict>
                <key>WFNotificationActionTitle</key>
                <string>📱 易班签到 - 步骤 1/4</string>
                <key>WFNotificationActionBody</key>
                <string>请在易班中选择学校「福州大学」，然后继续下一步</string>
                <key>WFNotificationActionSound</key>
                <true/>
            </dict>
        </dict>

        <!-- 7. 等待用户操作（给15秒） -->
        <dict>
            <key>WFWorkflowActionIdentifier</key>
            <string>is.workflow.actions.wait</string>
            <key>WFWorkflowActionParameters</key>
            <dict>
                <key>WFWaitTime</key>
                <integer>15</integer>
            </dict>
        </dict>

        <!-- 8. 通知：进入校本化 -->
        <dict>
            <key>WFWorkflowActionIdentifier</key>
            <string>is.workflow.actions.notification</string>
            <key>WFWorkflowActionParameters</key>
            <dict>
                <key>WFNotificationActionTitle</key>
                <string>📱 易班签到 - 步骤 2/4</string>
                <key>WFNotificationActionBody</key>
                <string>请点击「校本化」进入</string>
                <key>WFNotificationActionSound</key>
                <true/>
            </dict>
        </dict>

        <!-- 9. 等待 -->
        <dict>
            <key>WFWorkflowActionIdentifier</key>
            <string>is.workflow.actions.wait</string>
            <key>WFWorkflowActionParameters</key>
            <dict>
                <key>WFWaitTime</key>
                <integer>10</integer>
            </dict>
        </dict>

        <!-- 10. 通知：晚点签到 -->
        <dict>
            <key>WFWorkflowActionIdentifier</key>
            <string>is.workflow.actions.notification</string>
            <key>WFWorkflowActionParameters</key>
            <dict>
                <key>WFNotificationActionTitle</key>
                <string>📱 易班签到 - 步骤 3/4</string>
                <key>WFNotificationActionBody</key>
                <string>请点击「晚点签到」进入签到页面</string>
                <key>WFNotificationActionSound</key>
                <true/>
            </dict>
        </dict>

        <!-- 11. 等待 -->
        <dict>
            <key>WFWorkflowActionIdentifier</key>
            <string>is.workflow.actions.wait</string>
            <key>WFWorkflowActionParameters</key>
            <dict>
                <key>WFWaitTime</key>
                <integer>10</integer>
            </dict>
        </dict>

        <!-- 12. 通知：点击签到 -->
        <dict>
            <key>WFWorkflowActionIdentifier</key>
            <string>is.workflow.actions.notification</string>
            <key>WFWorkflowActionParameters</key>
            <dict>
                <key>WFNotificationActionTitle</key>
                <string>📱 易班签到 - 步骤 4/4</string>
                <key>WFNotificationActionBody</key>
                <string>请点击「签到」按钮完成签到 ✅</string>
                <key>WFNotificationActionSound</key>
                <true/>
            </dict>
        </dict>

        <!-- 13. 签到成功通知 -->
        <dict>
            <key>WFWorkflowActionIdentifier</key>
            <string>is.workflow.actions.notification</string>
            <key>WFWorkflowActionParameters</key>
            <dict>
                <key>WFNotificationActionTitle</key>
                <string>🎉 签到流程完成</string>
                <key>WFNotificationActionBody</key>
                <string>请在易班中确认签到结果</string>
                <key>WFNotificationActionSound</key>
                <true/>
            </dict>
        </dict>

        <!-- 14. 不在范围内 → 跳过 -->
        <dict>
            <key>WFWorkflowActionIdentifier</key>
            <string>is.workflow.actions.notification</string>
            <key>WFWorkflowActionParameters</key>
            <dict>
                <key>WFNotificationActionTitle</key>
                <string>📍 不在签到范围</string>
                <key>WFNotificationActionBody</key>
                <string>当前位置不在福州大学晋江校区500米范围内，已跳过签到</string>
                <key>WFNotificationActionSound</key>
                <true/>
            </dict>
        </dict>
    </array>
</dict>
</plist>
